{
  "name": "cursorbuddy",
  "displayName": "CursorBuddy",
  "description": "Voice + visual companion for VS Code",
  "version": "0.1.0",
  "publisher": "cursorbuddy",
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onCommand:cursorbuddy.startSession",
    "onView:cursorbuddy.sidebar"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorbuddy.startSession",
        "title": "CursorBuddy: Start Session"
      },
      {
        "command": "cursorbuddy.stopSession",
        "title": "CursorBuddy: Stop Session"
      },
      {
        "command": "cursorbuddy.setAuth",
        "title": "CursorBuddy: Set Auth Token"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cursorbuddy",
          "title": "CursorBuddy",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "cursorbuddy": [
        {
          "type": "webview",
          "id": "cursorbuddy.sidebar",
          "name": "CursorBuddy"
        }
      ]
    },
    "configuration": {
      "title": "CursorBuddy",
      "properties": {
        "cursorbuddy.connectionMode": {
          "type": "string",
          "enum": [
            "bridge",
            "direct"
          ],
          "default": "bridge",
          "description": "Connection mode: recommended bridge mode; direct mode is for advanced local testing."
        },
        "cursorbuddy.bridge.baseUrl": {
          "type": "string",
          "default": "http://127.0.0.1:8787",
          "description": "Bridge HTTP base URL used to mint realtime sessions"
        },
        "cursorbuddy.openclaw.baseUrl": {
          "type": "string",
          "default": "ws://localhost:9090",
          "description": "OpenClaw WebSocket URL for direct mode only"
        },
        "cursorbuddy.openclaw.workflow": {
          "type": "string",
          "default": "cursorbuddy_session",
          "description": "OpenClaw workflow name"
        },
        "cursorbuddy.openclaw.auth": {
          "type": "string",
          "default": "",
          "description": "OpenClaw auth token (stored in SecretStorage in production)"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "compile": "tsc --noEmit",
    "test": "node esbuild.config.js && tsc -p tsconfig.json && node dist/test/runTests.js",
    "package": "vsce package --out ../../dist/cursorbuddy.vsix"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.98.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.21.0",
    "mocha": "^10.8.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@cursorbuddy/shared": "*"
  }
}
