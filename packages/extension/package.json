{
  "name": "cursorbuddy",
  "displayName": "CursorBuddy",
  "description": "Larry support UI and local runtime controls for VS Code",
  "version": "0.1.0",
  "publisher": "cursorbuddy",
  "engines": {
    "vscode": "^1.98.0"
  },
  "categories": [
    "Other"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "cursorbuddy.startSession",
        "title": "CursorBuddy: Start Larry Session"
      },
      {
        "command": "cursorbuddy.stopSession",
        "title": "CursorBuddy: Stop Larry Session"
      },
      {
        "command": "cursorbuddy.setAuth",
        "title": "CursorBuddy: Set Larry Auth Token"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "cursorbuddy",
          "title": "CursorBuddy",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "cursorbuddy": [
        {
          "type": "webview",
          "id": "cursorbuddy.sidebar",
          "name": "Larry Support"
        }
      ]
    },
    "configuration": {
      "title": "CursorBuddy",
      "properties": {
        "cursorbuddy.connectionMode": {
          "type": "string",
          "enum": [
            "direct",
            "bridge"
          ],
          "default": "direct",
          "description": "Local runtime connection mode for Larry support: direct to OpenClaw or via bridge"
        },
        "cursorbuddy.openclaw.baseUrl": {
          "type": "string",
          "default": "ws://localhost:9090",
          "description": "OpenClaw WebSocket base URL used by the local Larry runtime"
        },
        "cursorbuddy.openclaw.workflow": {
          "type": "string",
          "default": "cursorbuddy_session",
          "description": "OpenClaw workflow name for Larry sessions"
        },
        "cursorbuddy.openclaw.auth": {
          "type": "string",
          "default": "",
          "description": "OpenClaw auth token for the local Larry runtime (stored in SecretStorage in production)"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.config.js",
    "watch": "node esbuild.config.js --watch",
    "compile": "tsc --noEmit",
    "test": "node esbuild.config.js && tsc -p tsconfig.json && node dist/test/runTests.js",
    "package": "vsce package --out ../../dist/cursorbuddy.vsix"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.98.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "@vscode/vsce": "^3.0.0",
    "esbuild": "^0.21.0",
    "mocha": "^10.8.2",
    "typescript": "^5.4.0"
  },
  "dependencies": {
    "@cursorbuddy/shared": "*"
  }
}
