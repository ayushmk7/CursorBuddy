{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build-all",
      "type": "shell",
      "command": "npm run build --workspace=packages/shared && npm run build --workspace=packages/openclaw && npm run build --workspace=packages/sidecar && npm run build --workspace=packages/extension",
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "shared"
      },
      "problemMatcher": []
    },
    {
      "label": "start-openclaw",
      "type": "shell",
      "command": "npm run build --workspace=packages/openclaw && node packages/openclaw/dist/index.js",
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated"
      },
      "problemMatcher": {
        "pattern": [
          {
            "regexp": "^\\[openclaw\\]",
            "message": 1
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "\\[openclaw\\]",
          "endsPattern": "listening on ws://"
        }
      }
    },
    {
      "label": "build-and-start-openclaw",
      "dependsOrder": "sequence",
      "dependsOn": ["build-all", "start-openclaw"],
      "problemMatcher": []
    },
    {
      "label": "start-bridge",
      "type": "shell",
      "command": "go run ./packages/bridge/cmd/bridge",
      "isBackground": true,
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": false,
        "panel": "dedicated"
      },
      "problemMatcher": {
        "pattern": [
          {
            "regexp": "^\\{.*\"msg\":\"bridge starting\".*\\}$",
            "message": 0
          }
        ],
        "background": {
          "activeOnStart": true,
          "beginsPattern": "bridge starting",
          "endsPattern": "bridge starting"
        }
      }
    },
    {
      "label": "build-start-real-stack",
      "dependsOrder": "sequence",
      "dependsOn": ["build-and-start-openclaw", "start-bridge"],
      "problemMatcher": []
    }
  ]
}
