# Vercel: add these in Project → Settings → Environment Variables
# Neon integration usually sets DATABASE_URL (and may set POSTGRES_URL).

POSTGRES_URL=
DATABASE_URL=
# Also recognized if your integration only exposes these:
# DATABASE_URL_UNPOOLED=
# NEON_DATABASE_URL=

# Optional: protect CSV export (GET /api/export-waitlist)
# Use header: Authorization: Bearer <your-secret>
# Or query: ?secret=<your-secret>
WAITLIST_EXPORT_SECRET=
